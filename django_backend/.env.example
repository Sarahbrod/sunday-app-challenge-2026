# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-python-m-secrets
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
# Leave blank to use SQLite (fine for local dev)
DATABASE_URL=postgres://user:password@localhost:5432/foba

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Access token lifetime in minutes
ACCESS_TOKEN_LIFETIME_MINUTES=15
# Refresh token lifetime in days
REFRESH_TOKEN_LIFETIME_DAYS=30

# ─── Token encryption (for storing OAuth tokens in DB) ────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ─── YouTube OAuth ─────────────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/connections/youtube/callback/

# ─── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
